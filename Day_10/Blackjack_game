import random
from art import logo
print(logo)
def deal_card():
    cards = [11,2,3,4,5,6,7,8,9,10,10,10,10]
    card = random.choice(cards)
    return card
def calculate_score(cards):
    """This is to check for a blackjack and if the sum of two cards is 21."""
    if sum(cards) == 21 and len(cards) == 2:
         return 0
    # """This is to check for an ace(11), so we use the remove function and if the sum of the cards
     #is above 21. """

    if 11 in cards and sum(cards) > 21:
        cards.remove(11)
        cards.append(1)
    return sum(cards)


def compare(u_score, c_score):
    """user_score and computer_score are both renamed because  we have used
     the same name in the function and out of the function in order not to confuse python rename ."""
    if u_score == c_score:
        print("It's a tie")
    elif c_score == 0:
        return "Lose, Opponent has a blackjack. "
    elif u_score == 0:
        return"Win, With a blackjack. "
    elif u_score > 21:
        return "You win"
    elif c_score > 21:
        return "Computer lose"
    else:
        return "Lose"
    
def play_game():
    user_card = []
    computer_card = []
    computer_score = -1
    """we set the computer_score to  a negative value so the computer_score on line 56 doesnt show undefined """
    user_score = -1
    is_game_over = False
    for i in range(2):
        new_card = deal_card()
        user_card.append(new_card)
        # print(user_card)
        computer_card.append(new_card)
        # print(computer_card)

    while not is_game_over:
        user_score = calculate_score(user_card)
        computer_score = calculate_score(computer_card)
        print(f"Your_cards : {user_card},  current score:{user_score}" )
        print(f"Computer's first card = {computer_card[0]}")

        if user_score == 0 or computer_score == 0  or user_score > 21:
            is_game_over = True
        else:
            phase_2 = input("Type y to get another card or type n to continue: ")
            if phase_2 == "y":
                user_card.append(deal_card())
                user_score = calculate_score(user_card)
            else:
                is_game_over = True

    while computer_score < 17 and computer_score != 0:
            computer_card.append(deal_card())
            computer_score = calculate_score(computer_card)
    print(f"Your final hand: {user_card},final score: {user_score}")
    print(f"Computer's final hand = {computer_card} , final score: {computer_score}")
    print(compare(user_score, computer_score))

while input("Do you want to play the blackjack game? Type y or n: ") == "y":
         print("\n "* 20)
         print(logo)
         play_game()

