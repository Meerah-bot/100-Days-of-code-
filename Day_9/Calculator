import random

from art import logo
print(logo)

def add(n1, n2):
    return n1 + n2

def subtract(n1, n2):
    return n1 - n2

def multiply(n1, n2):
    return n1 * n2

def divide(n1, n2):
    return n1 / n2
#
operations = {"+": add
        , "-": subtract,
        "*": multiply,
        "/": divide
        }

# print(operations["*"] (4,8))
def calculator():
    from art import logo
    print(logo)
    should_continue = True
    number_1 = int(input("Enter your first number: "))

    while should_continue:
        for operations_symbol in operations:
            print(operations_symbol)
        math_op = input("Pick an operator: ")
        if math_op in operations:
            number_2 = int(input("Enter your second number: "))
            result = operations[math_op](number_1, number_2)
            print(f"{number_1} {math_op} {number_2} = {result}")

        else:
            print("Invalid operator")
        phase_2 = input(f"Type y to continue calculating with {result}  or type n to start over:")

        if phase_2 == "y":
              number_1 = result
        else:
            should_continue = False
            print("\n" * 20)
            calculator()

calculator()